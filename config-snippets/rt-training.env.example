# ขั้นตอนที่ 1: ก๊อปปี้ไฟล์นี้ไปเป็นชื่อ rt-training.env
# $ cp config-snippets/rt-training.env.example config-snippets/rt-training.env
# ขั้นตอนที่ 2: กรอกค่า 9 ค่าด้านล่างให้ครบถ้วนแล้ว save

# -------------------------------------------------------------
# ส่วนที่ 1: Gateway & Telegram Bot
# -------------------------------------------------------------
# [วิธีหา]: ตั้งรหัสผ่านอะไรก็ได้ยาวๆ สำหรับเชื่อมระบบภายใน
REPLACE_OPENCLAW_GATEWAY_TOKEN=your_custom_gateway_token_here

# [วิธีหา]: เปิด Telegram คุยกับ @BotFather -> ส่งคำสั่ง /newbot -> ก๊อปปี้ Token ที่ได้มาใส่
REPLACE_TELEGRAM_BOT_TOKEN_MAIN=123456789:telegram_bot_token_here


# -------------------------------------------------------------
# ส่วนที่ 2: Training Area (กลุ่ม และ ผู้ควบคุม)
# -------------------------------------------------------------
# [วิธีหา Group ID]: ตั้งกลุ่มเป็นโหมด Topics -> ดึงบอท @getidsbot เข้ากลุ่มหลัก
# บอทจะพ่นเลขกลุ่มมาให้ เช่น -1001234567890 
# ⚠️ สำคัญ: ให้ใส่ "เฉพาะตัวเลข" ตัด -100 ออก (เช่น 1234567890)
REPLACE_TRAINING_GROUP_ID=1234567890

# [วิธีหา User ID]: คุยส่วนตัวกับบอท @userinfobot -> เอารหัสจากช่อง Id: มาใส่
REPLACE_TRAINER_USER_ID=123456789


# -------------------------------------------------------------
# ส่วนที่ 3: Topic IDs (ห้องย่อยของแต่ละ Agent)
# -------------------------------------------------------------
# [วิธีหา Topic ID]: ดึงบอท @getidsbot เข้าไปแชทใน "แต่ละ Topic" 
# บอทจะพ่น Message Thread ID กลับมาให้ทันที เอาเลขชุดนั้นมากรอกให้ตรงห้อง
REPLACE_TOPIC_ID_LEAD=1
REPLACE_TOPIC_ID_RECON=101
REPLACE_TOPIC_ID_WEBOPS=102
REPLACE_TOPIC_ID_ACCESS=103
REPLACE_TOPIC_ID_DEBRIEF=104
